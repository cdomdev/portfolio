---
import Card from "../components/cards/Card.astro";
import Code from "./icons/Code.astro";
---

<div class="flex justify-center items-center">
  <h2
    class="text-2xl md:text-3xl text-black font-bold dark:text-custom-color mb-1">
    Proyectos
  </h2>
  <Code />
</div>
<h3 class="text-base md:text-xl my-4 md:mb-4 px-2 text-center">
  Transformando conceptos en soluciones tecnológicas
</h3>
<div class="overflow-hidden m-auto flex w-vw-custom">
  <div class="flex flex-col whitespace-nowrap m-auto flex-wrap justify-center">
    <Card
      title="Suministros"
      text="Suministros es una tienda web que incluye funcionalidades completas de un e-comerce. La plataforma brinda una experiencia de usuarios optimizada para la navegacion y compra de productos."
      img="../../images/sumi.jpg"
    />
  </div>
</div>
