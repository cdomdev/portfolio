---
interface Props {
  title: string;
  text: string;
  img: string;
}

const { img, title, text } = Astro.props;
---

<div
  class="marquee-item min-w-[250px] m-2 shadow-md w-72 h-auto flex flex-col justify-between bg-white hover:shadow-xl hover:shadow-slate-100 transition duration-300 ease-in-out cursor-pointer md:w-37 lg:w-80"
  id="card">
  <img src={img} alt="sumi-img" class="w-full object-cover" />
  <div class="flex flex-col px-4 pt-1 pb-4 justify-start">
    <h4 class="text-lg text-black font-semibold mb-2">
      {title}
    </h4>
    <p class="text-black text-wrap text-sm">
      {text}
    </p>
  </div>
  <button
    class="flex items-center w-11/12 mx-auto text-lg border justify-center rounded-lg mt-2 mb-2 bg-gray-900 text-white hover:shadow-md delay-75 hover:text-slate-200 hover:stroke-slate-200">
    Ver proyecto
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="icon icon-tabler icon-tabler-arrow-narrow-right transition stroke-slate-200 hover:translate-x-2"
      width="40"
      height="40"
      viewBox="0 0 24 24"
      stroke-width="1.5"
      stroke="#2c3e50"
      fill="none"
      stroke-linecap="round"
      stroke-linejoin="round">
      <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
      <path d="M5 12l14 0"></path>
      <path d="M15 16l4 -4"></path>
      <path d="M15 8l4 4"></path>
    </svg>
  </button>
</div>
