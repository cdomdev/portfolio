---
import Whatsapp from "./icons/Whatsapp.astro";
---

<div class="">
  <h1 class="text-2xl my-2 text-black font-extrabold dark:text-white">
    Hola, soy
  </h1>
  <div class="flex flex-col gap-0 items-start">
    <div class="flex items-center">
      <span
        class="text-4xl m-0 text-custom-color typewriter font-bold lg:text-5xl">
        Carlos
      </span>
    </div>
    <div class="flex items-center gap-0">
      <span
        class="text-4xl m-0 text-custom-color font-extrabold typewriter lg:text-5x">
        Dominguez
      </span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="icon icon-tabler icon-tabler-hand-stop stroke-black greeting dark:stroke-white"
        width="44"
        height="44"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="#2c3e50"
        fill="none"
        stroke-linecap="round"
        stroke-linejoin="round">
        <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
        <path d="M8 13v-7.5a1.5 1.5 0 0 1 3 0v6.5"></path>
        <path d="M11 5.5v-2a1.5 1.5 0 1 1 3 0v8.5"></path>
        <path d="M14 5.5a1.5 1.5 0 0 1 3 0v6.5"></path>
        <path
          d="M17 7.5a1.5 1.5 0 0 1 3 0v8.5a6 6 0 0 1 -6 6h-2h.208a6 6 0 0 1 -5.012 -2.7a69.74 69.74 0 0 1 -.196 -.3c-.312 -.479 -1.407 -2.388 -3.286 -5.728a1.5 1.5 0 0 1 .536 -2.022a1.867 1.867 0 0 1 2.28 .28l1.47 1.47"
        ></path>
      </svg>
    </div>
  </div>
  <div>
    <p class="text-sm md:text-lg text-black dark:text-white">
      ¡Un desarrollador web fullstack. Creo interfaces fáciles de usar para
      empresas emergentes de rápido crecimiento.
    </p>
    <div class="flex gap-6 mt-2">
      <a
        class="flex gap-2 text-lg border hover:bg-[#50fd8fb5] hover:text-slate-100 dark:bg-[#50fd8fb5] dark:border-sky-50 font-bold bg-[#25d366] text-white py-1 px-3 rounded-md dark:hover:bg-[#25d366] duration-200"
        href="https://wa.me/573208132304"
        target="_blank">
        <div class="flex items-center duration-200">
          <Whatsapp />
          <p class="text-lg duration-150">Contáctame</p>
        </div>
      </a>
    </div>
  </div>
</div>

<div class="flex items-center justify-center w-full h-full relative mt-10">
  <div
    class="image-content flex justify-center items-center w-96 h-80 rounded-full overflow-hidden bg-slate-400 shadow-2xl shadow-slate-400 md:h-96 dark:bg-custom dark:shadow-slate-700">
    <img
      src="../images/person.png"
      alt="image-person"
      class="profile-image w-full h-full object-cover"
    />
  </div>
  <div
    class="icon-img absolute bg-slate-700 dark:bg-custom rounded-full p-1 top-icon top-1 right-0 md:right-36 lg:right-0 xl:right-7">
    <img src="../images/nd.png" alt="node" class="w-full h-full m-auto" />
  </div>
  <div
    class="icon-img absolute bg-slate-700 dark:bg-custom rounded-full w-20 p-1 bottom-10 left-0 md:left-36 lg:left-4 xl:left-6">
    <img src="../images/react.png" alt="react" class="m-auto w-full h-full" />
  </div>
  <div
    class="icon-img absolute bg-slate-700 dark:bg-custom rounded-full w-20 bottom-0 right-5 p-4 md:right-40 lg:bottom-3 lg:right-10 xl:right-7">
    <img src="../images/ts.png" alt="ts" class="w-full h-full" />
  </div>
</div>

<style>
  .typewriter {
    display: inline-block;
    overflow: hidden;
    padding: 0px 0px 5px 0px;
    white-space: nowrap;
    margin: 0 auto;
    letter-spacing: 0.15em;
    animation:
      typing 3s steps(30, end) forwards,
      blink-caret 0.75s step-end infinite;
  }

  .typewriter:nth-of-type(2) {
    animation:
      typing 3s steps(30, end) 3s forwards,
      blink-caret 0.75s step-end infinite 3s;
  }

  @keyframes typing {
    from {
      width: 0;
    }
    to {
      width: 100%;
    }
  }
  .greeting {
    display: inline-block;
    animation: greeting 2s infinite;
    transform-origin: 70% 70%;
  }

  @keyframes greeting {
    0% {
      transform: rotate(0deg);
    }
    25% {
      transform: rotate(15deg);
    }
    50% {
      transform: rotate(0deg);
    }
    75% {
      transform: rotate(-10deg);
    }
    100% {
      transform: rotate(0deg);
    }
  }

  @keyframes blink-caret {
    from,
    to {
      border-color: transparent;
    }
    50% {
      border-color: black;
    }
  }
</style>
