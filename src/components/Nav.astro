---

<header
  class="bg-gray-900 text-white font-sans-personality w-screen fixed top-0 right-0 z-50 lg:px-16">
  <nav
    class="container mx-auto p-1 flex justify-between items-center md:p-4 -z-50">
    <div class="flex items-center">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-9 h-9 md:w-10 md:h-10 mr-1 stroke-white"
        width="44"
        height="44"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="#2c3e50"
        fill="none"
        stroke-linecap="round"
        stroke-linejoin="round">
        <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
        <path d="M8 9l3 3l-3 3"></path>
        <path d="M13 15l3 0"></path>
        <path
          d="M3 4m0 2a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2z"
        ></path>
      </svg>
      <span class="text-base md:text-2xl font-bold">CDOM</span>
    </div>
    <ul class="text-sm flex gap-3 md:gap-6 md:text-lg lg:gap-10">
      <li><a href="#about" class="hover:underline">Servicios</a></li>
      <li><a href="#profile" class="hover:underline">Proyectos</a></li>
      <li><a href="#skills" class="hover:underline">Habilidades</a></li>
      <li><a href="#about" class="hover:underline">Sobre Mí</a></li>
    </ul>
    <div class="box-buttons-header md:flex gap-4 md:gap-8 hidden">
      <a
        class="github flex items-center gap-2 text-lg"
        href="https://github.com"
        target="_blank">
        <div class="rounded-full bg-white text-black gap-3 flex">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="icon icon-github icon-tabler icon-tabler-brand-github-filled"
            width="30"
            height="30"
            viewBox="0 -1.5 24 24"
            stroke-width="1.5"
            stroke="#2c3e50"
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
            <path
