              fill="currentColor"></path>
          </svg>
        </div>
        <p>Github</p>
      </a>
      <a
        class="flex gap-2 text-lg border border-sky-50 py-1 px-3 rounded-md"
        href="https://wa.me/573208132304"
        target="_blank">
        <div class="flex items-center hover:text-slate-400 delay-1000">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="icon icon-tabler icon-tabler-brand-whatsapp mr-1"
            width="35"
            height="35"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="#FFFFFF"
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="round">
