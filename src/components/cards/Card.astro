---
interface Props {
  title: string;
  text: string;
  img: string;
}

const { img, title, text } = Astro.props;
---

<div class="flex flex-col gap-y-16">
  <article
    class="flex flex-col space-x-0 space-y-8 group md:flex-row md:space-x-8 md:space-y-0">
    <div class="w-full md:w-1/2">
      <div
        class="relative flex flex-col items-center col-span-6 row-span-5 gap-8 transition border-none dark:shadow-2xl dark:border-slate-500 duration-500 ease-in-out transform shadow-sm overflow-clip rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-lg lg:border lg:border-gray-800 lg:hover:border-gray-700 lg:hover:bg-gray-800/50">
        <img
          alt="suministros store"
          class="object-cover object-top w-full h-40 transition duration-500 sm:h-64 md:scale-110 md:group-hover:scale-105"
          loading="lazy"
          src={img}
        />
      </div>
    </div>
    <div class="w-full md:w-1/2 md:max-w-lg">
      <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
        <font style="vertical-align: inherit;"
          ><font style="vertical-align: inherit;">{title}</font></font
        >
      </h3>
      <div class="flex flex-wrap mt-2">
        <ul class="flex flex-row mb-2 gap-x-2">
          <li>
            <span
              class="flex rounded-full text-xs bg-[#3a8fde] text-white py-1 px-2">
              <svg
                viewBox="0 0 256 228"
                width="256"
                class="size-4 mr-1"
                height="228"
                xmlns="http://www.w3.org/2000/svg"
                preserveAspectRatio="xMidYMid"
