---
interface Props {
    text: string;
}

const {text} = Astro.props
---

<div class="w-36 h-16 flex flex-row bg-white mt-2 items-center justify-center rounded-md shadow-xl shadow-slate-700 hover:shadow-slate-800 hover:shadow-sm transition-shadow ease-out duration-200 py-2 px-4 ">
    <slot/>
    <p class="text-black text-md ml-1">{text}</p>
</div>
